<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F2F6EE">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#1B5E20"
        android:padding="16dp"
        android:orientation="vertical">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🧾 IT Declaration &amp; Tax"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold"/>
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Investment Declaration, Proof Upload &amp; Tax Calculator"
            android:textColor="#A5D6A7"
            android:textSize="12sp"/>
    </LinearLayout>

    <!-- FY + Status row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        android:padding="12dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:elevation="2dp">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="FY:"
            android:textSize="13sp"
            android:textColor="#424242"
            android:layout_marginEnd="8dp"/>
        <Spinner
            android:id="@+id/spinnerITFY"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"/>
        <TextView
            android:id="@+id/tvDeclStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="NEW"
            android:textSize="11sp"
            android:textStyle="bold"
            android:padding="4dp"
            android:layout_marginStart="8dp"/>
    </LinearLayout>

    <!-- HR Comment -->
    <TextView
        android:id="@+id/tvHrComment"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFEBEE"
        android:textColor="#C62828"
        android:textSize="12sp"
        android:padding="10dp"
        android:visibility="gone"/>

    <!-- Tabs — dynamically populated in code -->
    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tabsITDecl"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        app:tabMode="scrollable"
        app:tabTextColor="#757575"
        app:tabSelectedTextColor="#2E7D32"
        app:tabIndicatorColor="#2E7D32"/>

    <!-- ══════════════════════════════════════════════════════
         PANE 0 — My Declaration
    ══════════════════════════════════════════════════════ -->
    <ScrollView
        android:id="@+id/paneDeclaration"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <!-- Regime -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                app:cardCornerRadius="10dp"
                app:cardElevation="2dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Tax Regime" android:textSize="13sp" android:textStyle="bold"
                        android:textColor="#2E7D32" android:layout_marginBottom="8dp"/>
                    <RadioGroup android:id="@+id/rgRegime" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:orientation="horizontal">
                        <RadioButton android:id="@+id/rbOld" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="Old Regime"
                            android:textSize="13sp" android:checked="true" android:layout_marginEnd="20dp"/>
                        <RadioButton android:id="@+id/rbNew" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="New Regime"
                            android:textSize="13sp"/>
                    </RadioGroup>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- HRA -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="10dp" app:cardCornerRadius="10dp" app:cardElevation="2dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="14dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="🏠 HRA Exemption" android:textSize="13sp" android:textStyle="bold"
                        android:textColor="#2E7D32" android:layout_marginBottom="10dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Monthly Rent Paid (₹)" android:textSize="12sp" android:textColor="#616161"/>
                    <EditText android:id="@+id/etRent" android:layout_width="match_parent"
                        android:layout_height="wrap_content" android:inputType="numberDecimal"
                        android:hint="0" android:textSize="14sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Landlord Name" android:textSize="12sp" android:textColor="#616161"
                        android:layout_marginTop="8dp"/>
                    <EditText android:id="@+id/etLandlord" android:layout_width="match_parent"
                        android:layout_height="wrap_content" android:hint="Full name" android:textSize="14sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Landlord PAN" android:textSize="12sp" android:textColor="#616161"
                        android:layout_marginTop="8dp"/>
                    <EditText android:id="@+id/etLandlordPan" android:layout_width="match_parent"
                        android:layout_height="wrap_content" android:hint="ABCDE1234F"
                        android:inputType="textCapCharacters" android:textSize="14sp" android:maxLength="10"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- 80C -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="10dp" app:cardCornerRadius="10dp" app:cardElevation="2dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="14dp">
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:text="💰 Section 80C — Max ₹1,50,000" android:textSize="13sp"
                        android:textStyle="bold" android:textColor="#2E7D32" android:layout_marginBottom="10dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="PF Contribution (₹)" android:textSize="12sp" android:textColor="#616161"/>
                    <EditText android:id="@+id/et80cPf" android:layout_width="match_parent"
                        android:layout_height="wrap_content" android:inputType="numberDecimal" android:hint="0" android:textSize="14sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="PPF (₹)" android:textSize="12sp" android:textColor="#616161" android:layout_marginTop="8dp"/>
                    <EditText android:id="@+id/et80cPpf" android:layout_width="match_parent"
                        android:layout_height="wrap_content" android:inputType="numberDecimal" android:hint="0" android:textSize="14sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="LIC Premium (₹)" android:textSize="12sp" android:textColor="#616161" android:layout_marginTop="8dp"/>
                    <EditText android:id="@+id/et80cLic" android:layout_width="match_parent"
                        android:layout_height="wrap_content" android:inputType="numberDecimal" android:hint="0" android:textSize="14sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="ELSS / Mutual Fund (₹)" android:textSize="12sp" android:textColor="#616161" android:layout_marginTop="8dp"/>
                    <EditText android:id="@+id/et80cElss" android:layout_width="match_parent"
                        android:layout_height="wrap_content" android:inputType="numberDecimal" android:hint="0" android:textSize="14sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="NSC (₹)" android:textSize="12sp" android:textColor="#616161" android:layout_marginTop="8dp"/>
                    <EditText android:id="@+id/et80cNsc" android:layout_width="match_parent"
                        android:layout_height="wrap_content" android:inputType="numberDecimal" android:hint="0" android:textSize="14sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Home Loan Principal (₹)" android:textSize="12sp" android:textColor="#616161" android:layout_marginTop="8dp"/>
                    <EditText android:id="@+id/et80cHomeLoan" android:layout_width="match_parent"
                        android:layout_height="wrap_content" android:inputType="numberDecimal" android:hint="0" android:textSize="14sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Tuition Fees (₹)" android:textSize="12sp" android:textColor="#616161" android:layout_marginTop="8dp"/>
                    <EditText android:id="@+id/et80cTuition" android:layout_width="match_parent"
                        android:layout_height="wrap_content" android:inputType="numberDecimal" android:hint="0" android:textSize="14sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Other 80C (₹)" android:textSize="12sp" android:textColor="#616161" android:layout_marginTop="8dp"/>
                    <EditText android:id="@+id/et80cOther" android:layout_width="match_parent"
                        android:layout_height="wrap_content" android:inputType="numberDecimal" android:hint="0" android:textSize="14sp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- 80D -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="10dp" app:cardCornerRadius="10dp" app:cardElevation="2dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="14dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="🏥 Section 80D — Medical Insurance" android:textSize="13sp"
                        android:textStyle="bold" android:textColor="#2E7D32" android:layout_marginBottom="10dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Self / Family Premium (₹) — Max ₹25,000" android:textSize="12sp" android:textColor="#616161"/>
                    <EditText android:id="@+id/et80dSelf" android:layout_width="match_parent"
                        android:layout_height="wrap_content" android:inputType="numberDecimal" android:hint="0" android:textSize="14sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Parents Premium (₹) — Max ₹50,000" android:textSize="12sp"
                        android:textColor="#616161" android:layout_marginTop="8dp"/>
                    <EditText android:id="@+id/et80dParents" android:layout_width="match_parent"
                        android:layout_height="wrap_content" android:inputType="numberDecimal" android:hint="0" android:textSize="14sp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Other Deductions -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="10dp" app:cardCornerRadius="10dp" app:cardElevation="2dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="14dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="📑 Other Deductions" android:textSize="13sp"
                        android:textStyle="bold" android:textColor="#2E7D32" android:layout_marginBottom="10dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="24(b) Home Loan Interest (₹) — Max ₹2,00,000" android:textSize="12sp" android:textColor="#616161"/>
                    <EditText android:id="@+id/et24bHomeLoan" android:layout_width="match_parent"
                        android:layout_height="wrap_content" android:inputType="numberDecimal" android:hint="0" android:textSize="14sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="80E Education Loan Interest (₹)" android:textSize="12sp"
                        android:textColor="#616161" android:layout_marginTop="8dp"/>
                    <EditText android:id="@+id/et80eEduLoan" android:layout_width="match_parent"
                        android:layout_height="wrap_content" android:inputType="numberDecimal" android:hint="0" android:textSize="14sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="80G Donations (₹)" android:textSize="12sp"
                        android:textColor="#616161" android:layout_marginTop="8dp"/>
                    <EditText android:id="@+id/et80gDonation" android:layout_width="match_parent"
                        android:layout_height="wrap_content" android:inputType="numberDecimal" android:hint="0" android:textSize="14sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="80CCD(1B) NPS (₹) — Max ₹50,000" android:textSize="12sp"
                        android:textColor="#616161" android:layout_marginTop="8dp"/>
                    <EditText android:id="@+id/et80ccdNps" android:layout_width="match_parent"
                        android:layout_height="wrap_content" android:inputType="numberDecimal" android:hint="0" android:textSize="14sp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Summary + Buttons -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="16dp" app:cardCornerRadius="10dp" app:cardElevation="2dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="14dp" android:background="#E8F5E9">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:layout_marginBottom="12dp">
                        <TextView android:id="@+id/tvTotal80c" android:layout_width="0dp"
                            android:layout_height="wrap_content" android:layout_weight="1"
                            android:text="80C: ₹0" android:textSize="13sp" android:textStyle="bold"
                            android:textColor="#2E7D32"/>
                        <TextView android:id="@+id/tvTotalDeductions" android:layout_width="0dp"
                            android:layout_height="wrap_content" android:layout_weight="1"
                            android:text="Total Savings: ₹0" android:textSize="13sp" android:textStyle="bold"
                            android:textColor="#1B5E20" android:gravity="end"/>
                    </LinearLayout>
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="end">
                        <Button android:id="@+id/btnSaveDraft"
                            android:layout_width="wrap_content" android:layout_height="40dp"
                            android:text="💾 Save Draft" android:textSize="13sp"
                            android:backgroundTint="#FFFFFF" android:textColor="#2E7D32"
                            android:layout_marginEnd="10dp"/>
                        <Button android:id="@+id/btnSubmitDecl"
                            android:layout_width="wrap_content" android:layout_height="40dp"
                            android:text="✅ Submit to HR" android:textSize="13sp"
                            android:backgroundTint="#2E7D32" android:textColor="#FFFFFF"/>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

    <!-- ══════════════════════════════════════════════════════
         PANE 1 — Upload Proof (ALL roles)
    ══════════════════════════════════════════════════════ -->
    <ScrollView
        android:id="@+id/paneProof"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:visibility="gone">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <!-- Info banner -->
            <TextView
                android:id="@+id/tvProofInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#E3F2FD"
                android:textColor="#1565C0"
                android:textSize="12sp"
                android:padding="10dp"
                android:layout_marginBottom="10dp"
                android:text="📎 Upload supporting documents for your declaration. Save/Submit your declaration first."/>

            <!-- Proof items container — populated dynamically -->
            <LinearLayout
                android:id="@+id/llProofContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"/>

        </LinearLayout>
    </ScrollView>

    <!-- ══════════════════════════════════════════════════════
         PANE 2 — Tax Calculator (ALL roles)
    ══════════════════════════════════════════════════════ -->
    <ScrollView
        android:id="@+id/paneTax"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:visibility="gone">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="10dp">
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:layout_marginEnd="6dp"
                    app:cardCornerRadius="10dp" app:cardElevation="2dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="vertical" android:padding="14dp" android:gravity="center">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="OLD REGIME" android:textSize="11sp" android:textStyle="bold"
                            android:textColor="#757575" android:layout_marginBottom="6dp"/>
                        <TextView android:id="@+id/tvOldRegimeTax"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="—" android:textSize="18sp" android:textStyle="bold"
                            android:textColor="#212121" android:gravity="center"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:layout_marginStart="6dp"
                    app:cardCornerRadius="10dp" app:cardElevation="2dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="vertical" android:padding="14dp" android:gravity="center">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="NEW REGIME" android:textSize="11sp" android:textStyle="bold"
                            android:textColor="#757575" android:layout_marginBottom="6dp"/>
                        <TextView android:id="@+id/tvNewRegimeTax"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="—" android:textSize="18sp" android:textStyle="bold"
                            android:textColor="#212121" android:gravity="center"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>

            <TextView android:id="@+id/tvRecommended"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:background="#E8F5E9" android:padding="12dp"
                android:textSize="13sp" android:textStyle="bold"
                android:textColor="#1B5E20" android:layout_marginBottom="10dp"
                android:gravity="center" android:text=""/>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="16dp" app:cardCornerRadius="10dp" app:cardElevation="2dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="14dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="📋 Old Regime Breakdown" android:textSize="13sp" android:textStyle="bold"
                        android:textColor="#2E7D32" android:layout_marginBottom="10dp"/>
                    <TextView android:id="@+id/tvTaxBreakdown"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:textSize="12sp" android:textColor="#424242"
                        android:fontFamily="monospace" android:lineSpacingMultiplier="1.4"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

    <!-- ══════════════════════════════════════════════════════
         PANE 3 — HR Review (HR + Accounts only)
    ══════════════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/paneHR"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:visibility="gone">

        <!-- Filter bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#FFFFFF"
            android:padding="10dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:elevation="2dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Status:" android:textSize="12sp" android:textColor="#424242"
                android:layout_marginEnd="6dp"/>
            <Spinner android:id="@+id/spinnerHRStatus"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1"/>
            <Button android:id="@+id/btnRefreshHR"
                android:layout_width="wrap_content" android:layout_height="36dp"
                android:text="🔄" android:textSize="13sp"
                android:backgroundTint="#E8F5E9" android:textColor="#2E7D32"
                android:layout_marginStart="8dp"/>
        </LinearLayout>

        <!-- HR list -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">
            <LinearLayout
                android:id="@+id/llHRContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="10dp"/>
        </ScrollView>
    </LinearLayout>

</LinearLayout>