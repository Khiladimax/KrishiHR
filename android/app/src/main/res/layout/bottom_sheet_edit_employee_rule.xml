<?xml version="1.0" encoding="utf-8"?>
<!--
  Progressive edit bottom sheet for GeofenceAdminFragment.
  Opens when user taps an employee card.
  Shows current rule + all pickers needed to change it.
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/surface"
    android:paddingBottom="24dp">

    <!-- Drag handle -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="4dp"
        android:background="#CCCCCC"
        android:alpha="0.7" />

    <!-- Employee header row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="12dp"
        android:paddingBottom="14dp">

        <TextView
            android:id="@+id/bsInitials"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:gravity="center"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="@color/primary"
            android:background="@drawable/bg_icon_green"
            android:layout_marginEnd="14dp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/bsName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary" />

            <TextView
                android:id="@+id/bsCode"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textColor="@color/text_hint"
                android:layout_marginTop="1dp" />

        </LinearLayout>

        <!-- Current assignment badge -->
        <TextView
            android:id="@+id/bsRuleBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:textStyle="bold"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingTop="5dp"
            android:paddingBottom="5dp"
            android:background="@drawable/bg_badge_universal" />

    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="16dp" />

    <!-- Section label -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingBottom="8dp"
        android:text="Change assignment rule"
        android:textSize="12sp"
        android:textStyle="bold"
        android:textColor="@color/text_secondary"
        android:letterSpacing="0.06" />

    <!-- Rule Type Spinner -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="10dp"
        android:background="@drawable/bg_spinner_field"
        android:gravity="center_vertical"
        android:paddingStart="6dp"
        android:paddingEnd="4dp">

        <Spinner
            android:id="@+id/bsSpRule"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />
    </LinearLayout>

    <!-- Office Location Spinner (shown only for Office rule) -->
    <LinearLayout
        android:id="@+id/bsLlLocation"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="10dp"
        android:background="@drawable/bg_spinner_field"
        android:gravity="center_vertical"
        android:paddingStart="6dp"
        android:paddingEnd="4dp"
        android:visibility="gone">

        <Spinner
            android:id="@+id/bsSpLocation"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />
    </LinearLayout>

    <!-- State Spinner (shown for State or District rule) -->
    <LinearLayout
        android:id="@+id/bsLlState"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="10dp"
        android:background="@drawable/bg_spinner_field"
        android:gravity="center_vertical"
        android:paddingStart="6dp"
        android:paddingEnd="4dp"
        android:visibility="gone">

        <Spinner
            android:id="@+id/bsSpState"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />
    </LinearLayout>

    <!-- District Spinner (shown only for District rule, after state chosen) -->
    <LinearLayout
        android:id="@+id/bsLlDistrict"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="20dp"
        android:background="@drawable/bg_spinner_field"
        android:gravity="center_vertical"
        android:paddingStart="6dp"
        android:paddingEnd="4dp"
        android:visibility="gone">

        <Spinner
            android:id="@+id/bsSpDistrict"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />
    </LinearLayout>

    <!-- Apply button -->
    <Button
        android:id="@+id/bsBtnApply"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:text="Save changes"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="@android:color/white"
        android:textAllCaps="false"
        android:background="@drawable/bg_button_apply" />

</LinearLayout>
