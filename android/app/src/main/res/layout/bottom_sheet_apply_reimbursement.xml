<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/white">

    <!-- Handle -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="4dp"
        android:background="#CBD5E1"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:maxHeight="600dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="💸 Apply Reimbursement"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:paddingBottom="12dp"/>

            <!-- Request Title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Request Title"
                android:textSize="12sp"
                android:textColor="#64748b"
                android:paddingBottom="4dp"/>

            <EditText
                android:id="@+id/etReimbTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="e.g., Field Visit Expenses - March"
                android:textSize="14sp"
                android:padding="12dp"
                android:background="@drawable/bg_spinner_field"
                android:layout_marginBottom="14dp"/>

            <!-- Expense Items Container -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="EXPENSE ITEMS"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="#64748b"
                android:paddingBottom="8dp"/>

            <LinearLayout
                android:id="@+id/llExpenseItems"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"/>

            <!-- Add Item Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAddExpenseItem"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:text="+ Add Expense Item"
                android:textSize="13sp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="8dp"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>

            <!-- Submit -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSubmitReimbursement"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="Submit Request"
                android:textSize="15sp"
                android:layout_marginTop="4dp"/>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
