<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.KrishiHR.Splash" parent="Theme.SplashScreen">
        <!-- WHITE background — matches your SplashActivity white bg -->
        <item name="windowSplashScreenBackground">#FFFFFF</item>
        <!-- TRANSPARENT icon — this kills the small logo flash -->
        <item name="windowSplashScreenAnimatedIcon">@drawable/splash_icon_transparent</item>
        <item name="windowSplashScreenIconBackgroundColor">@android:color/transparent</item>
        <item name="postSplashScreenTheme">@style/Theme.KrishiHR</item>
        <item name="android:statusBarColor">#FFFFFF</item>
        <item name="android:navigationBarColor">#FFFFFF</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar">true</item>
    </style>
</resources>