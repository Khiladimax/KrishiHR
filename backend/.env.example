# KrishiHR Backend — Environment Variables
# Copy this to .env for local dev, or set these in Railway dashboard for production

PORT=3000
NODE_ENV=production

# Neon PostgreSQL (get from neon.tech dashboard)
DB_HOST=your-neon-host.neon.tech
DB_PORT=5432
DB_NAME=hrms_db
DB_USER=your_neon_user
DB_PASSWORD=your_neon_password

# JWT
JWT_SECRET=change_this_to_a_strong_random_secret_key
JWT_EXPIRES_IN=8h

# CORS
CORS_ORIGIN=*

# Cloudinary (free photo storage — get from cloudinary.com dashboard)
# Without these, photos are stored as base64 in DB (works but slower)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── TURN Server (Required for cross-network WebRTC calls) ─────────────────────
# Without a proper TURN server, calls only work on the same WiFi network.
#
# Option A: Self-hosted Coturn (recommended for production)
#   1. Install coturn on a VPS: apt install coturn
#   2. Edit /etc/turnserver.conf:
#        realm=yourdomain.com
#        use-auth-secret
#        static-auth-secret=SAME_VALUE_AS_TURN_SECRET_BELOW
#        no-tls  (or configure TLS with your cert)
#        listening-port=3478
#        tls-listening-port=5349
#        min-port=49152
#        max-port=65535
#        log-file=/var/log/turnserver.log
#   3. sudo systemctl enable coturn && sudo systemctl start coturn
#   4. Open UDP/TCP 3478 and 5349, and UDP 49152-65535 in your firewall.
#
# Option B: Managed TURN (Twilio, Metered.ca paid plan, Xirsys)
#   Use fixed username/credential format and skip TURN_SECRET.
#
TURN_SERVER_URL=turn:your-turn-server.example.com:3478
TURN_SECRET=replace_with_a_strong_random_secret_matching_coturn_config
TURN_TTL_SECONDS=86400
