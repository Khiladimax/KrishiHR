# KrishiHR Backend — Environment Variables
# Copy this to .env for local dev, or set these in Railway dashboard for production

PORT=3000
NODE_ENV=production

# Neon PostgreSQL (get from neon.tech dashboard)
DB_HOST=your-neon-host.neon.tech
DB_PORT=5432
DB_NAME=hrms_db
DB_USER=your_neon_user
DB_PASSWORD=your_neon_password

# JWT
JWT_SECRET=change_this_to_a_strong_random_secret_key
JWT_EXPIRES_IN=8h

# CORS
CORS_ORIGIN=*

# Cloudinary (free photo storage — get from cloudinary.com dashboard)
# Without these, photos are stored as base64 in DB (works but slower)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Firebase Admin SDK — Push Notifications (FCM)
# Option A (Railway / cloud): paste the full serviceAccount.json content as a single-line JSON string
# Option B (local dev): set path to serviceAccount.json file and use GOOGLE_APPLICATION_CREDENTIALS
# Get serviceAccount.json from Firebase Console → Project Settings → Service Accounts → Generate new private key
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"...","client_email":"..."}
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/serviceAccount.json

